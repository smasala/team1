// Prisma schema — owned by the data-access library (single source of DB truth).
//
// DB: Supabase Postgres. The connection string lives in .env (DATABASE_URL,
// pointed at the Supabase session pooler) and is passed to PrismaClient via the
// pg driver adapter (libs/data-access/src/lib/prisma.service.ts). Nothing else
// in the codebase references the database directly.
//
// Portability note: all status fields are plain String columns with the allowed
// values documented inline (rather than Prisma enums). This keeps migrations
// trivial and lets the schema also run on SQLite for offline/local work.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: the connection URL lives in prisma.config.ts (datasource.url),
  // read from DATABASE_URL, and is passed to PrismaClient via the pg adapter.
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth & tenancy
// ---------------------------------------------------------------------------

/// A tenant. Every User, Offer and Invoice belongs to exactly one organisation;
/// all business APIs are scoped to the caller's organisationId (multi-tenancy).
model Organisation {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  offers     Offer[]
  invoices   Invoice[]
  categories Category[]
}

/// An application user. `id` is our own generated cuid (the app's identity key,
/// referenced by offers/invoices). `authId` separately holds the Supabase Auth
/// UUID — it is NOT 1:1 with `id`: invited team members exist with no authId
/// until they first sign in, and the auth provider could change. Login verifies
/// the password with Supabase, then resolves the User by `authId`. The test user
/// seeded by seed.ts has authId 68e75f68-1ee2-46f4-9fee-2bbb2613a02d.
///
/// `role`: ADMIN | EMPLOYEE (controls team management). Every user is attached
/// to an Organisation (provisioned on first sign-in if missing).
model User {
  id             String   @id @default(cuid())
  authId         String?  @unique
  email          String?  @unique
  fullName       String?
  role           String   @default("EMPLOYEE")
  organisationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  offers       Offer[]
  invoices     Invoice[]

  @@index([organisationId])
}

// ---------------------------------------------------------------------------
// Catalogue (seeded from scripts/baupreise-catalogue.json; +30% markup baked
// into `price` at seed time)
// ---------------------------------------------------------------------------

/// Top-level trade category (e.g. "Maurerarbeiten"). Owned by an organisation
/// (multi-tenant catalogue); `slug` is unique per organisation. Subcategories
/// and items inherit tenancy through their parent category.
model Category {
  id             String   @id @default(cuid())
  slug           String
  name           String
  sourceUrl      String?
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation  Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  items         Item[]

  @@unique([organisationId, slug])
  @@index([organisationId])
}

/// Optional grouping inside a category (e.g. "Kalksandsteine"). Unique per
/// category by name.
model Subcategory {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items    Item[]

  @@unique([categoryId, name])
  @@index([categoryId])
}

/// A priced catalogue line. `price` is the single sell price: the source
/// baseline already has the catalogue-wide markup baked in at seed time.
model Item {
  id            String   @id @default(cuid())
  description   String
  unit          String
  price         Float
  currency      String   @default("EUR")
  categoryId    String
  subcategoryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// 768-dim embedding of `description` for semantic retrieval (Phase 1).
  /// Typed via Unsupported() because Prisma has no native pgvector type. The
  /// `vector` extension and the ANN/FTS/trigram indexes are created out-of-band
  /// by prisma/sql/*.sql (the extensions must exist before `db push` can create
  /// this column). Nullable: backfilled by the embedding service (#12) at seed
  /// time and on item create/update.
  embedding     Unsupported("vector(768)")?

  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory  Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  offerItems   OfferItem[]
  invoiceItems InvoiceItem[]

  @@index([categoryId])
  @@index([subcategoryId])
}

// ---------------------------------------------------------------------------
// Offers
// ---------------------------------------------------------------------------

/// A customer proposal. Monetary totals are denormalised snapshots kept in sync
/// by the service layer so historical offers never shift when the catalogue
/// changes. `status`: DRAFT | SENT | ACCEPTED | REJECTED.
model Offer {
  id              String   @id @default(cuid())
  number          String?  @unique
  title           String?
  status          String   @default("DRAFT")
  customerName    String?
  customerEmail   String?
  customerAddress String?
  notes           String?
  currency        String   @default("EUR")
  subtotal        Float    @default(0)
  taxRate         Float    @default(0)
  taxAmount       Float    @default(0)
  total           Float    @default(0)
  userId          String
  organisationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  items        OfferItem[]
  invoices     Invoice[]

  @@index([userId])
  @@index([organisationId])
}

/// A snapshot line on an offer. `itemId` links back to the catalogue (nullable
/// for ad-hoc/AI-added lines); `unitPrice`/`lineTotal` are frozen at add time.
model OfferItem {
  id          String   @id @default(cuid())
  offerId     String
  itemId      String?
  description  String
  unit        String?
  quantity    Float    @default(1)
  unitPrice   Float
  lineTotal   Float
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  item  Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([itemId])
}

// ---------------------------------------------------------------------------
// Invoices
// ---------------------------------------------------------------------------

/// An invoice, optionally generated from an accepted offer. `status`:
/// DRAFT | SENT | PAID | CANCELLED.
model Invoice {
  id              String    @id @default(cuid())
  number          String?   @unique
  offerId         String?
  status          String    @default("DRAFT")
  customerName    String?
  customerEmail   String?
  customerAddress String?
  notes           String?
  currency        String    @default("EUR")
  subtotal        Float     @default(0)
  taxRate         Float     @default(0)
  taxAmount       Float     @default(0)
  total           Float     @default(0)
  issuedAt        DateTime?
  dueAt           DateTime?
  paidAt          DateTime?
  userId          String
  organisationId  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  offer        Offer?        @relation(fields: [offerId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]

  @@index([userId])
  @@index([organisationId])
  @@index([offerId])
}

/// A snapshot line on an invoice (mirrors OfferItem).
model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  itemId      String?
  description  String
  unit        String?
  quantity    Float    @default(1)
  unitPrice   Float
  lineTotal   Float
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item    Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([itemId])
}

// ---------------------------------------------------------------------------
// Sample model (keeps the /health DB probe working end-to-end)
// ---------------------------------------------------------------------------

/// Minimal sample model so the stack is wired end-to-end.
model Note {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
