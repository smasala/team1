# Copy to .env and fill in.

# --- Database (Supabase Postgres) ---
# Use the session pooler (port 5432) so `prisma db push` works. The node pg
# driver needs uselibpqcompat=true to accept Supabase's pooler cert.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true"

# --- Auth (backend) ---
# Your Supabase project's JWT secret (Settings -> API -> JWT Secret). The API
# verifies Bearer tokens with this and signs the tokens it mints at /auth/login.
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Supabase project URL + anon key. /auth/login posts the user's email/password
# to Supabase Auth (GoTrue) with these to verify credentials server-side, then
# resolves the matching app user by User.authId.
SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_ANON_KEY="<anon public key>"

# --- Frontend ---
VITE_API_URL="http://localhost:3000/api"

# --- AI (Gemini) ---
# Required: the offer drafter understands prompts via the Gemini API
# (non-deterministic). Without it /ai/draft-offer returns an error.
GEMINI_API_KEY="..."
# Optional model override (default: gemini-2.5-flash).
# GEMINI_MODEL="gemini-2.5-flash"

# --- Offline/local fallback ---
# Set provider="sqlite" in libs/data-access/prisma/schema.prisma to use:
# DATABASE_URL="file:./dev.db"
