# Copy to .env and fill in.

# --- Database (Supabase Postgres) ---
# Use the session pooler (port 5432) so `prisma db push` works. The node pg
# driver needs uselibpqcompat=true to accept Supabase's pooler cert.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true"

# --- Auth (backend) ---
# Your Supabase project's JWT secret (Settings -> API -> JWT Secret). The API
# verifies Bearer tokens with this; the dev-login endpoint signs with it too.
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# --- Frontend ---
VITE_API_URL="http://localhost:3000/api"

# Supabase client auth (optional). Set both to enable email/password sign-in;
# leave unset to use the backend dev-login (seeded test account).
# VITE_SUPABASE_URL="https://<project>.supabase.co"
# VITE_SUPABASE_ANON_KEY="<anon public key>"

# --- AI (Gemini) ---
# When set, the offer drafter understands prompts via the Gemini API
# (non-deterministic). Leave unset to use the built-in deterministic parser.
# GEMINI_API_KEY="..."
# Optional model override (default: gemini-2.5-flash).
# GEMINI_MODEL="gemini-2.5-flash"

# --- Offline/local fallback ---
# Set provider="sqlite" in libs/data-access/prisma/schema.prisma to use:
# DATABASE_URL="file:./dev.db"
