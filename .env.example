# Copy to .env and fill in. The scaffold ships with SQLite for zero-setup local dev.
DATABASE_URL="file:./dev.db"

# Supabase/Postgres (set provider="postgresql" in libs/data-access/prisma/schema.prisma):
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?schema=public"

# Frontend -> API base URL (Vite)
VITE_API_URL="http://localhost:3000/api"
